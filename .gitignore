# ===============================
# .gitignore for KAZA Downscaling
# ===============================

# ----------------------------------------------------------------
# Ignore all large LU_ref_PLUM_SSPs data and subfolders by default
LU_ref_dataset/LU_ref_PLUM_SSPs/

# ================= HISTORIC RULES FOR INITIAL TESTING (KEPT FOR RECORD) =================
# # These rules were initially used to only allow Angola test files:
# !LU_ref_dataset/LU_ref_PLUM_SSPs/SSP1_RCP26/SSP1_RCP26_fraction/SSP1_RCP26_fraction_croped/
# LU_ref_dataset/LU_ref_PLUM_SSPs/SSP1_RCP26/SSP1_RCP26_fraction/SSP1_RCP26_fraction_croped/*
# !LU_ref_dataset/LU_ref_PLUM_SSPs/SSP1_RCP26/SSP1_RCP26_fraction/SSP1_RCP26_fraction_croped/Angola_SSP1_RCP26_LUC_fractions_*.tif

# ================= MAIN RULES TO TRACK ALL CROPPED OUTPUT =================

# Unignore parent folders so Git will descend into them and see nested files
!LU_ref_dataset/
!LU_ref_dataset/LU_ref_PLUM_SSPs/
!LU_ref_dataset/LU_ref_PLUM_SSPs/*/
!LU_ref_dataset/LU_ref_PLUM_SSPs/*/*_fraction/
!LU_ref_dataset/LU_ref_PLUM_SSPs/*/*_fraction/*_fraction_croped/
!LU_ref_dataset/LU_ref_PLUM_SSPs/*/*_fraction/*_fraction_croped/**

# ----------------------------------------------------------------
# Ignore common R project/working files
.Rproj.user/
.RData
.Rhistory
downscaling_log.txt

# (add other temp or cache files here if needed)
